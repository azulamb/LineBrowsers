<Window x:Class="LineBrowsers.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="バージョン情報" SizeToContent="Height" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <StackPanel Margin="24,20">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Image Source="/app.ico" Width="32" Height="32" Margin="0,0,12,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="LineBrowsers"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextForegroundBrush}"/>
                <TextBlock x:Name="VersionText"
                           FontSize="12"
                           Foreground="{DynamicResource MutedForegroundBrush}"/>
                <TextBlock x:Name="CommitText"
                           FontSize="11"
                           Foreground="{DynamicResource MutedForegroundBrush}"/>
            </StackPanel>
        </StackPanel>

        <Separator Margin="0,0,0,12" Background="{DynamicResource SeparatorBrush}"/>

        <TextBlock Foreground="{DynamicResource TextForegroundBrush}" FontSize="12" Margin="0,0,0,4">
            <Run Text="Author: "/>
            <Run Text="Hiroki" FontWeight="SemiBold"/>
        </TextBlock>
        <TextBlock FontSize="12" Margin="0,0,0,16">
            <Hyperlink x:Name="GitHubLink" RequestNavigate="GitHubLink_RequestNavigate">
                GitHub
            </Hyperlink>
        </TextBlock>

        <Button Content="OK" Width="80" HorizontalAlignment="Right"
                IsDefault="True" IsCancel="True" Padding="8,4"/>
    </StackPanel>
</Window>
