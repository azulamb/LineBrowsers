<Window x:Class="LineBrowsers.Dialogs.InjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="380" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TypeLabel" Grid.Row="0"
                   FontWeight="Bold" FontSize="13" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextForegroundBrush}"/>

        <TextBox x:Name="CodeBox" Grid.Row="1"
                 AcceptsReturn="True"
                 FontFamily="Consolas" FontSize="13"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="DeleteButton" Content="{DynamicResource Btn.Delete}" Width="72" Margin="0,0,8,0"
                    Visibility="Collapsed" Click="Delete_Click"/>
            <Button Content="{DynamicResource Btn.Save}" Width="72" Margin="0,0,8,0"
                    IsDefault="True" Click="OK_Click"/>
            <Button Content="{DynamicResource Btn.Cancel}" Width="72" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
