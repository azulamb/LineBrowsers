<Window x:Class="LineBrowsers.Dialogs.SessionManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title.Sessions}" Height="340" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView x:Name="SessionList" Grid.Row="0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{DynamicResource Col.SessionName}" Width="260"
                                    DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{DynamicResource Btn.Delete}"
                                        Tag="{Binding SessionId}"
                                        Click="Delete_Click"
                                        Padding="6,2"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Button Grid.Row="1" Content="{DynamicResource Btn.Close}"
                HorizontalAlignment="Right"
                Width="80" Margin="0,10,0,0"
                IsCancel="True"/>
    </Grid>
</Window>
