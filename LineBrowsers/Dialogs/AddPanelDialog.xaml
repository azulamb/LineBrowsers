<Window x:Class="LineBrowsers.Dialogs.AddPanelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title.AddPanel}" Height="240" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="{DynamicResource Label.Url}"
               Foreground="{DynamicResource TextForegroundBrush}" VerticalAlignment="Center"/>
        <TextBox x:Name="UrlBox" Grid.Row="0" Grid.Column="1"
                 Margin="0,4" Text="https://x.com" VerticalContentAlignment="Center"/>

        <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource Label.Width}"
               Foreground="{DynamicResource TextForegroundBrush}" VerticalAlignment="Center"/>
        <TextBox x:Name="WidthBox" Grid.Row="1" Grid.Column="1"
                 Margin="0,4" Text="400" VerticalContentAlignment="Center"/>

        <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource Label.Session}"
               Foreground="{DynamicResource TextForegroundBrush}" VerticalAlignment="Center"/>
        <ComboBox x:Name="SessionCombo" Grid.Row="2" Grid.Column="1"
                  Margin="0,4" SelectionChanged="SessionCombo_SelectionChanged"/>

        <Label x:Name="NewSessionLabel" Grid.Row="3" Grid.Column="0"
               Content="{DynamicResource Label.Name}"
               Foreground="{DynamicResource TextForegroundBrush}"
               VerticalAlignment="Center" Visibility="Collapsed"/>
        <TextBox x:Name="NewSessionNameBox" Grid.Row="3" Grid.Column="1"
                 Margin="0,4" Visibility="Collapsed" VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Btn.OK}" Width="72" Margin="0,0,8,0"
                    IsDefault="True" Click="OK_Click"/>
            <Button Content="{DynamicResource Btn.Cancel}" Width="72" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
