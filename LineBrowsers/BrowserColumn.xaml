<UserControl x:Class="LineBrowsers.BrowserColumn"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- URL bar -->
            <Grid Grid.Row="0" Background="{DynamicResource UrlBarBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="←"
                        x:Name="BackButton"
                        Click="Back_Click"
                        Margin="4,2,0,2" Padding="6,2"
                        IsEnabled="False"
                        Background="{DynamicResource ButtonBackgroundBrush}"
                        Foreground="{DynamicResource ButtonForegroundBrush}"/>
                <TextBox x:Name="UrlBar" Grid.Column="1"
                         Margin="4,2" VerticalContentAlignment="Center"
                         KeyDown="UrlBar_KeyDown"
                         Background="{DynamicResource TextBoxBackgroundBrush}"
                         Foreground="{DynamicResource TextForegroundBrush}"
                         BorderThickness="0" FontSize="12"/>
                <Button Grid.Column="2" Content="{DynamicResource Btn.Go}"
                        Click="Navigate_Click"
                        Margin="0,2,2,2" Padding="6,2"
                        Background="{DynamicResource ButtonBackgroundBrush}"
                        Foreground="{DynamicResource ButtonForegroundBrush}"/>
                <Button Grid.Column="3" Content="⋮"
                        Click="Menu_Click"
                        Margin="0,2,4,2" Padding="6,2"
                        ToolTip="{DynamicResource Tooltip.InjectMenu}"
                        Background="{DynamicResource ButtonBackgroundBrush}"
                        Foreground="{DynamicResource ButtonForegroundBrush}"/>
            </Grid>

            <wv2:WebView2 x:Name="WebView" Grid.Row="1"/>
        </Grid>

        <!-- Resize drag handle -->
        <Thumb Grid.Column="1"
               x:Name="ResizeThumb"
               Cursor="SizeWE"
               DragDelta="ResizeThumb_DragDelta">
            <Thumb.Template>
                <ControlTemplate>
                    <Border Background="{DynamicResource ResizeThumbBrush}"/>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</UserControl>
