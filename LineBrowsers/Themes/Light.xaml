<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush"       Color="#F5F5F5"/>
    <SolidColorBrush x:Key="ToolBarBackgroundBrush"      Color="#E8E8E8"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush"       Color="#DEDEDE"/>
    <SolidColorBrush x:Key="HeaderForegroundBrush"       Color="#333333"/>
    <SolidColorBrush x:Key="UrlBarBackgroundBrush"       Color="#ECECEC"/>
    <SolidColorBrush x:Key="TextBoxBackgroundBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextBoxBorderBrush"          Color="#AAAAAA"/>
    <SolidColorBrush x:Key="TextForegroundBrush"         Color="#1A1A1A"/>
    <SolidColorBrush x:Key="MutedForegroundBrush"        Color="#666666"/>
    <SolidColorBrush x:Key="ButtonBackgroundBrush"       Color="#D4D4D4"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush"       Color="#333333"/>
    <SolidColorBrush x:Key="ButtonBorderBrush"           Color="#AAAAAA"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush"  Color="#C0C0C0"/>
    <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="#B0B0B0"/>
    <SolidColorBrush x:Key="MenuBackgroundBrush"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MenuForegroundBrush"         Color="#1A1A1A"/>
    <SolidColorBrush x:Key="MenuBorderBrush"             Color="#CCCCCC"/>
    <SolidColorBrush x:Key="MenuHighlightBrush"          Color="#CCE4F7"/>
    <SolidColorBrush x:Key="SeparatorBrush"              Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ResizeThumbBrush"            Color="#C0C0C0"/>
</ResourceDictionary>
