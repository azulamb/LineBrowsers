<Window x:Class="LineBrowsers.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{DynamicResource Title.Preview}"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        Background="{DynamicResource WindowBackgroundBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="0" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource UrlBarBackgroundBrush}"
              WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="←"
                    x:Name="BackButton"
                    Click="Back_Click"
                    IsEnabled="False"
                    Margin="4,2,0,2" Padding="6,2"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource ButtonForegroundBrush}"/>
            <TextBox x:Name="UrlBar" Grid.Column="1"
                     Margin="4,4" VerticalContentAlignment="Center"
                     KeyDown="UrlBar_KeyDown"
                     Background="{DynamicResource TextBoxBackgroundBrush}"
                     Foreground="{DynamicResource TextForegroundBrush}"
                     BorderThickness="0" FontSize="12"/>
            <Button Grid.Column="2" Content="{DynamicResource Btn.Go}"
                    Click="Navigate_Click"
                    Margin="0,2,2,2" Padding="6,2"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource ButtonForegroundBrush}"/>
            <Button Grid.Column="3" Content="✕"
                    Click="Close_Click"
                    Margin="0,2,4,2" Padding="6,2"
                    ToolTip="{DynamicResource Tooltip.ClosePreview}"
                    Style="{StaticResource CloseButtonStyle}"/>
        </Grid>

        <wv2:WebView2 x:Name="WebView" Grid.Row="1" Margin="6,0,6,6"/>
    </Grid>
</Window>
