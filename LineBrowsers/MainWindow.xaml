<Window x:Class="LineBrowsers.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LineBrowsers" Height="900" Width="1400"
        WindowState="Maximized"
        UseLayoutRounding="True"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content area -->
        <DockPanel Grid.Row="0" LastChildFill="True">

            <!-- Scrollbar docked at bottom so WebView2 HWNDs never overlap it -->
            <ScrollBar DockPanel.Dock="Bottom"
                       x:Name="MainScrollBar"
                       Orientation="Horizontal"
                       Visibility="Collapsed"
                       SmallChange="80"
                       LargeChange="400"
                       Scroll="MainScrollBar_Scroll"/>

            <Canvas x:Name="PanelHost"
                    ClipToBounds="True"
                    SizeChanged="PanelHost_SizeChanged"/>

        </DockPanel>

        <!-- Bottom bar -->
        <Border Grid.Row="1"
                Background="{DynamicResource ToolBarBackgroundBrush}"
                Padding="8,4">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Content="{DynamicResource Main.AddPanel}" Click="AddPanel_Click" Padding="8,4"/>
                <Separator Width="1" Margin="6,2" Background="{DynamicResource SeparatorBrush}"/>
                <Button Content="{DynamicResource Main.Sessions}" Click="Sessions_Click" Padding="8,4"/>
                <Separator Width="1" Margin="6,2" Background="{DynamicResource SeparatorBrush}"/>
                <Button Content="⚙" ToolTip="{DynamicResource Tooltip.Settings}"
                        Click="SettingsButton_Click"
                        Width="32" FontSize="13" Padding="0"/>
                <Button Content="ℹ" ToolTip="{DynamicResource Tooltip.About}"
                        Click="AboutButton_Click"
                        Width="32" FontSize="13" Padding="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
